# Copy this file to .env and fill with your database credentials for production or hosting
# Place the .env file at the project root (same folder as this file).

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# Optional: other environment variables used by the backend
# CLIENT_ID=1
# PAYMENT_GATEWAY_KEY=...
