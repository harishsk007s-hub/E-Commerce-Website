# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Environment: 'development' or 'production'
APP_ENV=production

# Base URL of the application. In production, this is your Render deployment URL (e.g. https://my-app.onrender.com).
BASE_URL=https://<your_app_name>.onrender.com
FRONTEND_URL=https://<your_app_name>.onrender.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Remote hosted MySQL database details for production
DB_HOST=<production_database_hostname>
DB_PORT=3306
DB_NAME=<production_database_name>
DB_USER=<production_database_user>
DB_PASS=<production_database_password>
DB_CHARSET=utf8mb4

# ==========================================
# FRONTEND API CONFIGURATIONS (Vite compile-time)
# ==========================================
# Base relative URL paths for APIs in production. DO NOT change these for Render.
VITE_PHP_API_URL=/backend/api/v1/
VITE_UPLOADS_URL=/backend/uploads/

# ==========================================
# EMAIL CONFIGURATION (SMTP / PHPMailer & Fallbacks)
# ==========================================
# The hostname of your SMTP server (e.g., smtp.sendgrid.net, mail.goappalam.in)
SMTP_HOST=<your_smtp_server_host>
# The username/login for the SMTP server
SMTP_USER=<your_smtp_username>
# The password for the SMTP server
SMTP_PASS=<your_smtp_password>
# The SMTP port (usually 465 for SSL or 587 for TLS/STARTTLS)
SMTP_PORT=465
# The connection security type: 'ssl' or 'tls'
SMTP_SECURE=ssl
# The name to display in the 'From' column of emails (e.g., 'Goappalam Store')
EMAIL_FROM_NAME=Goappalam
# The address that appears as the sender (e.g., sales@goappalam.in)
EMAIL_FROM_ADDRESS=<your_from_email_address>

# ==========================================
# SECURITY & API GATEWAY
# ==========================================
# Internal key to secure API endpoints. Must match on frontend and PHP backend.
X_API_KEY=sk_live_zenco_123456789
# Comma-separated list of allowed CORS domains
ALLOWED_ORIGINS=https://<your_app_name>.onrender.com

# ==========================================
# PAYMENT GATEWAY (Razorpay)
# ==========================================
# Razorpay public key ID (e.g., rzp_live_xxxxxxxx or rzp_test_xxxxxxxx)
RAZORPAY_KEY_ID=<your_razorpay_key_id>
# Razorpay private key secret
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>
