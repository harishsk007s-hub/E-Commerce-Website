{"id":2002,"date":"2020-09-03T09:03:48","date_gmt":"2020-09-03T09:03:48","guid":{"rendered":"https:\/\/demo2wpopal.b-cdn.net\/poco\/?page_id=2002"},"modified":"2021-04-07T14:15:03","modified_gmt":"2021-04-07T14:15:03","slug":"our-history","status":"publish","type":"page","link":"https:\/\/goappalam.in\/our-history\/","title":{"rendered":"Our History"},"content":{"rendered":"\t\t<div data-elementor-type=\"wp-page\" data-elementor-id=\"2002\" class=\"elementor elementor-2002\" data-elementor-post-type=\"page\">\n\t\t\t\t\t\t<div class=\"elementor-section elementor-top-section elementor-element elementor-element-8f2e847 elementor-section-stretched elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-id=\"8f2e847\" data-element_type=\"section\" data-settings=\"{&quot;stretch_section&quot;:&quot;section-stretched&quot;}\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-no\">\n\t\t\t\t\t<div class=\"elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-cccd108\" data-id=\"cccd108\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-a93a55d elementor-widget elementor-widget-heading\" data-id=\"a93a55d\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h4 class=\"elementor-heading-title elementor-size-default\">About Our Food<\/h4>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-1074549 elementor-widget__width-initial elementor-widget elementor-widget-heading\" data-id=\"1074549\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Delivering Awesome  Since 1960<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\